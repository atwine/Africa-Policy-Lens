# ── Virtual environment ────────────────────────────────────────
venv/
.venv/
env/

# ── Python cache ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── ChromaDB persistent storage (large binary, rebuilt by ingest.py) ──
chroma_db/

# ── Source PDFs are committed directly (all <1 MB, text-based) ──
# docs/*.pdf  ← intentionally NOT excluded

# ── OS artefacts ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Devin CLI local config (machine-specific) ──────────────────
.devin/

# ── Environment variables / secrets ───────────────────────────
.env
.env.*
*.key

# ── Build artefacts ───────────────────────────────────────────
dist/
build/
*.egg-info/

# ── Session history (user-specific, not for repo) ─────────────
sessions/*.json

# ── Logs ──────────────────────────────────────────────────────
*.log
